{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "OpenMeteo": {
        "GeocodingUrl": "https://geocoding-api.open-meteo.com/v1/search",
        "ForecastUrl": "https://api.open-meteo.com/v1/forecast",
        "Language": "it"
    },

    "Cache": {
        "WeatherTtlMinutes": 60
    },

    "Ui": {
        "MaxWeatherCards": 5
    },

    "Http": {
        "TimeoutSeconds": 10
    },
    "AllowedHosts": "*"
}
